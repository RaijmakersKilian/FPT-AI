# ===================================================================
# FPT AI — Backend environment (.env)
# Copy this file to  backend/.env  and fill in the real values.
# backend/.env is gitignored — NEVER commit real keys.
# Every value below has a "WHERE:" note telling you where to find it.
# ===================================================================

# --- Database: Supabase Postgres -----------------------------------
# The backend connects with psycopg; sslmode=require is added in code.
# WHERE: Supabase Dashboard -> Project Settings -> Database ->
#        "Connection string" -> URI tab. Use the Connection Pooler URI
#        (port 6543) for the app. Replace [YOUR-PASSWORD] with your DB password.
# Format: postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# --- Local file storage (current backend behaviour) ----------------
# Where uploaded videos and generated PDFs are written on the server.
# (Kept even with Supabase Storage: the backend still writes here today.)
UPLOAD_DIR=storage/videos
REPORT_OUTPUT_DIR=storage/reports_pdf

# --- Supabase project: API + Storage -------------------------------
# WHERE: Supabase Dashboard -> Project Settings -> API.
# Project URL (also used by the frontend). This is https://<project-ref>.supabase.co
# — it is NOT a key. Do not paste the publishable/anon key here.
SUPABASE_URL=https://<project-ref>.supabase.co

# anon / public key — safe to expose to the browser (with RLS on).
# WHERE: Project Settings -> API -> "Project API keys" -> anon public
#        (or the "Publishable" key on newer projects).
SUPABASE_ANON_KEY=<anon-public-key>

# service_role (secret) key — BACKEND ONLY. Never put this in the frontend.
# Needed only if the backend uploads/serves files via Supabase Storage.
# WHERE: Project Settings -> API -> "Project API keys" -> service_role (secret).
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret-key>

# --- Supabase Storage buckets --------------------------------------
# WHERE: Supabase Dashboard -> Storage -> Buckets. Create them if missing
#        and note whether each is Public or Private (affects URL signing).
SUPABASE_VIDEOS_BUCKET=videos
SUPABASE_MODELS_BUCKET=3Dmodels
