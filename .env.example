# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Your existing PostgreSQL database
# When running via Docker, use host.docker.internal instead of localhost:
DATABASE_URL=postgresql+psycopg://ftpai_user:change_this_password@host.docker.internal:5432/ftpai_db

# Port the dashboard is available on (default: 8000)
PORT=8000
